# Azure OpenAI Configuration (Required)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your-azure-openai-api-key

# API Authentication (Required for voice-to-text and text-to-json APIs)
PRESCRIPTION_API_KEY=your-secret-api-key-for-mobile-clients

# Alternative: If using different Azure instances
# AZURE_OPENAI_WHISPER_ENDPOINT=https://your-whisper-resource.openai.azure.com
# AZURE_OPENAI_WHISPER_KEY=your-whisper-api-key
